<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>ISS Facility Journeys | Professional Experience View</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap');

:root{
  --iss-dark:#030037;
  --iss-blue:#153ac7;
  --iss-azure:#0084ff;
  --iss-sand:#decfb9;
  --iss-cream:#f6f3ed;
  --iss-line:#d9dce8;
  --iss-text:#19213d;
  --iss-muted:#6f7894;
  --iss-white:#ffffff;
  --iss-panel:#f8faff;
  --iss-success:#eaf5ee;
  --iss-warning:#fff4e8;
  --shadow-soft:0 16px 40px rgba(3,0,55,.08);
  --shadow-card:0 8px 24px rgba(21,58,199,.08);
  --radius-xl:22px;
  --radius-lg:16px;
  --radius-md:12px;
}

*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  font-family:'DM Sans',sans-serif;
  background:linear-gradient(180deg,#f7f9fc 0%, #f3efe8 100%);
  color:var(--iss-text);
  min-height:100vh;
}

.header-shell{
  background:
    radial-gradient(circle at top right, rgba(0,132,255,.18), transparent 26%),
    radial-gradient(circle at left center, rgba(222,207,185,.18), transparent 24%),
    var(--iss-dark);
  color:var(--iss-white);
}

header{
  max-width:1380px;
  margin:0 auto;
  padding:28px 28px 42px;
}

.topbar{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:24px;
  margin-bottom:28px;
}

.brand{
  display:flex;
  align-items:center;
  gap:16px;
}

.brand-mark{
  width:56px;
  height:56px;
  border-radius:14px;
  background:linear-gradient(135deg,var(--iss-azure),#2c57eb);
  display:flex;
  align-items:center;
  justify-content:center;
  font-weight:700;
  letter-spacing:.08em;
  box-shadow:0 10px 28px rgba(0,132,255,.28);
}

.brand-title{font-size:1.4rem;font-weight:700;line-height:1.1}
.brand-sub{font-size:.92rem;color:rgba(255,255,255,.72);margin-top:4px}

.header-pill{
  padding:10px 16px;
  border-radius:999px;
  background:rgba(255,255,255,.08);
  border:1px solid rgba(255,255,255,.14);
  color:rgba(255,255,255,.8);
  font-size:.82rem;
  white-space:nowrap;
}

.hero{
  display:grid;
  grid-template-columns:1.25fr .95fr;
  gap:24px;
  align-items:stretch;
}

.hero-copy,
.hero-card{
  border:1px solid rgba(255,255,255,.12);
  background:rgba(255,255,255,.06);
  border-radius:24px;
  padding:28px;
  backdrop-filter:blur(8px);
}

.hero h1{
  font-size:clamp(2rem,3.8vw,3rem);
  line-height:1.02;
  margin-bottom:16px;
}

.hero p{
  color:rgba(255,255,255,.78);
  line-height:1.7;
  max-width:760px;
}

.hero-grid{
  margin-top:24px;
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr));
  gap:14px;
}

.hero-stat{
  background:rgba(255,255,255,.06);
  border:1px solid rgba(255,255,255,.08);
  border-radius:18px;
  padding:16px;
}

.hero-stat strong{display:block;font-size:1.2rem;margin-bottom:6px}
.hero-stat span{font-size:.86rem;color:rgba(255,255,255,.72);line-height:1.5}

.hero-card h2{font-size:1.05rem;margin-bottom:18px}
.hero-card ul{list-style:none;display:grid;gap:14px}
.hero-card li{
  padding:14px 16px;
  border-radius:16px;
  background:rgba(255,255,255,.06);
  border:1px solid rgba(255,255,255,.08);
}
.hero-card li strong{display:block;font-size:.95rem;margin-bottom:4px}
.hero-card li span{font-size:.88rem;color:rgba(255,255,255,.72);line-height:1.55}

.main{
  max-width:1380px;
  margin:0 auto;
  padding:28px;
}

.control-panel{
  margin-top:-26px;
  background:var(--iss-white);
  border:1px solid rgba(21,58,199,.08);
  border-radius:24px;
  box-shadow:var(--shadow-soft);
  padding:22px;
  position:relative;
  z-index:5;
}

.control-top{
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:18px;
  margin-bottom:18px;
}

.control-title h3{font-size:1.25rem;margin-bottom:6px}
.control-title p{color:var(--iss-muted);line-height:1.6;max-width:840px}

.tabs{
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr));
  gap:12px;
}

.tab{
  border:1px solid var(--iss-line);
  background:#fbfcff;
  border-radius:18px;
  padding:18px 20px;
  text-align:left;
  cursor:pointer;
  transition:.22s ease;
}
.tab:hover{transform:translateY(-2px);border-color:rgba(21,58,199,.28);box-shadow:var(--shadow-card)}
.tab.active{
  background:linear-gradient(180deg,#eff4ff 0%, #ffffff 100%);
  border-color:rgba(21,58,199,.28);
  box-shadow:var(--shadow-card);
}
.tab small{display:block;font-size:.78rem;color:var(--iss-muted);margin-bottom:8px;text-transform:uppercase;letter-spacing:.06em}
.tab strong{display:block;font-size:1rem;color:var(--iss-text);margin-bottom:8px}
.tab span{display:block;font-size:.9rem;color:var(--iss-muted);line-height:1.55}

.view{
  margin-top:26px;
  display:none;
  grid-template-columns:minmax(0,1.45fr) minmax(320px,.8fr);
  gap:22px;
}
.view.active{display:grid}

.panel{
  background:var(--iss-white);
  border:1px solid rgba(25,33,61,.08);
  border-radius:var(--radius-xl);
  box-shadow:var(--shadow-soft);
}

.panel-header{
  padding:26px 26px 18px;
  border-bottom:1px solid #edf0f6;
}
.panel-kicker{
  display:inline-flex;
  align-items:center;
  gap:8px;
  border-radius:999px;
  padding:7px 12px;
  background:var(--iss-panel);
  color:var(--iss-blue);
  font-size:.78rem;
  letter-spacing:.05em;
  text-transform:uppercase;
  font-weight:700;
  margin-bottom:14px;
}
.panel-header h2{font-size:1.55rem;margin-bottom:10px}
.panel-header p{color:var(--iss-muted);line-height:1.7;max-width:920px}

.journey{
  padding:18px 18px 26px 18px;
}

.step{
  display:grid;
  grid-template-columns:92px minmax(0,1fr);
  gap:14px;
  align-items:stretch;
}

.step-rail{
  position:relative;
  display:flex;
  flex-direction:column;
  align-items:center;
  padding-top:16px;
}
.step-index{
  width:44px;
  height:44px;
  border-radius:50%;
  border:2px solid var(--iss-azure);
  background:linear-gradient(180deg,#fff,#eef5ff);
  color:var(--iss-blue);
  display:flex;
  align-items:center;
  justify-content:center;
  font-weight:700;
  box-shadow:0 6px 18px rgba(0,132,255,.12);
  z-index:2;
}
.step-line{
  position:absolute;
  top:60px;
  bottom:-10px;
  width:2px;
  background:linear-gradient(180deg,rgba(0,132,255,.18),rgba(222,207,185,.55));
}
.step:last-child .step-line{display:none}
.step-phase{
  margin-top:12px;
  text-align:center;
  font-size:.72rem;
  text-transform:uppercase;
  letter-spacing:.08em;
  color:var(--iss-muted);
  font-weight:700;
  line-height:1.4;
}

.step-card{
  background:linear-gradient(180deg,#ffffff 0%, #fbfcff 100%);
  border:1px solid #e9edf6;
  border-radius:18px;
  padding:18px 18px 18px 20px;
  margin-bottom:16px;
  transition:.22s ease;
  cursor:pointer;
  position:relative;
  overflow:hidden;
}
.step-card::before{
  content:'';
  position:absolute;
  left:0;
  top:0;
  bottom:0;
  width:4px;
  background:linear-gradient(180deg,var(--iss-sand),var(--iss-azure));
  opacity:.78;
}
.step-card:hover,
.step-card.open{
  border-color:rgba(21,58,199,.22);
  box-shadow:var(--shadow-card);
  transform:translateY(-1px);
}

.step-top{
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:18px;
}
.step-label{
  font-size:.78rem;
  font-weight:700;
  letter-spacing:.06em;
  color:var(--iss-blue);
  text-transform:uppercase;
  margin-bottom:8px;
}
.step-title{font-size:1.08rem;font-weight:700;margin-bottom:8px}
.step-summary{color:var(--iss-muted);line-height:1.65;font-size:.95rem}
.step-toggle{
  width:34px;
  height:34px;
  border-radius:10px;
  border:1px solid #d9e4fb;
  display:flex;
  align-items:center;
  justify-content:center;
  color:var(--iss-blue);
  font-weight:700;
  flex-shrink:0;
  background:#f5f9ff;
}
.step-card.open .step-toggle{background:var(--iss-blue);color:#fff;border-color:var(--iss-blue)}

.step-detail{display:none;padding-top:16px;margin-top:16px;border-top:1px solid #edf0f6}
.step-card.open .step-detail{display:block}

.detail-grid{
  display:grid;
  grid-template-columns:repeat(2,minmax(0,1fr));
  gap:14px;
}
.detail-box{
  background:var(--iss-cream);
  border:1px solid #ebe3d4;
  border-radius:14px;
  padding:14px;
}
.detail-box h4{font-size:.84rem;text-transform:uppercase;letter-spacing:.06em;color:var(--iss-muted);margin-bottom:10px}
.detail-box ul{list-style:none;display:grid;gap:8px}
.detail-box li{font-size:.9rem;line-height:1.55;color:var(--iss-text)}

.badge-row{display:flex;flex-wrap:wrap;gap:8px;margin-top:16px}
.badge{
  display:inline-flex;
  align-items:center;
  gap:8px;
  padding:8px 12px;
  border-radius:999px;
  font-size:.8rem;
  font-weight:600;
  border:1px solid transparent;
}
.badge.service{background:#eef4ff;color:var(--iss-blue);border-color:#d6e3ff}
.badge.tech{background:#f4f7fb;color:#394467;border-color:#dde4f2}
.badge.value{background:var(--iss-success);color:#215638;border-color:#cfe7d6}
.badge.risk{background:var(--iss-warning);color:#8a5a12;border-color:#f1dcc0}

.side-panel{padding:24px}
.side-panel h3{font-size:1.18rem;margin-bottom:16px}
.side-stack{display:grid;gap:14px}
.info-card{
  border:1px solid #e9edf6;
  border-radius:18px;
  padding:18px;
  background:linear-gradient(180deg,#ffffff,#fafcff);
}
.info-card h4{font-size:.94rem;margin-bottom:10px}
.info-card p{font-size:.9rem;line-height:1.65;color:var(--iss-muted);margin-bottom:10px}
.info-card ul{list-style:none;display:grid;gap:8px}
.info-card li{font-size:.9rem;line-height:1.55}

.metric-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}
.metric{
  border-radius:16px;
  padding:14px;
  background:var(--iss-panel);
  border:1px solid #dce8ff;
}
.metric strong{display:block;font-size:1rem;color:var(--iss-blue);margin-bottom:4px}
.metric span{font-size:.84rem;color:var(--iss-muted);line-height:1.45}

.legend{display:grid;gap:8px}
.legend-row{display:flex;align-items:center;gap:10px;font-size:.88rem;color:var(--iss-muted)}
.legend-chip{width:12px;height:12px;border-radius:50%}
.legend-chip.service{background:#dce8ff}
.legend-chip.tech{background:#dfe6f4}
.legend-chip.value{background:#d4ecd8}
.legend-chip.risk{background:#f8dfc3}

.footer-note{
  margin-top:22px;
  background:var(--iss-dark);
  color:#fff;
  border-radius:22px;
  padding:22px 24px;
  display:grid;
  grid-template-columns:1.2fr .8fr;
  gap:20px;
}
.footer-note h3{margin-bottom:10px}
.footer-note p{color:rgba(255,255,255,.76);line-height:1.7}
.footer-note ul{list-style:none;display:grid;gap:8px}
.footer-note li{color:rgba(255,255,255,.8);line-height:1.55}

@media (max-width:1100px){
  .hero,.view,.footer-note{grid-template-columns:1fr}
}

@media (max-width:840px){
  .tabs{grid-template-columns:1fr}
  .step{grid-template-columns:76px minmax(0,1fr)}
  .detail-grid,.metric-grid,.hero-grid{grid-template-columns:1fr}
  .topbar,.control-top{flex-direction:column;align-items:flex-start}
}

@media (max-width:560px){
  header,.main{padding:18px}
  .hero-copy,.hero-card,.control-panel,.side-panel,.panel-header{padding:18px}
  .journey{padding:12px}
  .step-card{padding:16px}
}
</style>
</head>
<body>
  <div class="header-shell">
    <header>
      <div class="topbar">
        <div class="brand">
          <div class="brand-mark">ISS</div>
          <div>
            <div class="brand-title">Integrated Facility Journeys</div>
            <div class="brand-sub">Professional interactive view of service delivery, technology enablement and on-site coordination</div>
          </div>
        </div>
        <div class="header-pill">ISS Nederland | Experience, Operations and Technology</div>
      </div>

      <div class="hero">
        <div class="hero-copy">
          <h1>Drie perspectieven op één locatie, verbonden door één geïntegreerde dienstverlening.</h1>
          <p>
            Deze interactieve plaat laat zien hoe ISS de dagelijkse ervaring op locatie organiseert voor drie doelgroepen: de pandbewoner,
            de bezoeker en de sitemanager. Per journey wordt zichtbaar hoe operationele dienstverlening, hospitality, gebouwbeheer,
            data en technologie samenkomen in één consistente service-ervaring.
          </p>
          <div class="hero-grid">
            <div class="hero-stat">
              <strong>3 journeys</strong>
              <span>Van gebruiker tot regisseur van de operatie.</span>
            </div>
            <div class="hero-stat">
              <strong>1 service model</strong>
              <span>Mens, proces en technologie in samenhang.</span>
            </div>
            <div class="hero-stat">
              <strong>Datagedreven</strong>
              <span>Van signalering tot opvolging en rapportage.</span>
            </div>
          </div>
        </div>
        <div class="hero-card">
          <h2>Wat deze visual zichtbaar maakt</h2>
          <ul>
            <li>
              <strong>De beleving op locatie</strong>
              <span>Hoe ISS bijdraagt aan comfort, gastvrijheid, veiligheid, productiviteit en continuïteit.</span>
            </li>
            <li>
              <strong>De technologie erachter</strong>
              <span>Sensoren, meldingen, workflows, AI-ondersteuning, dashboards en integraties die de dienstverlening versterken.</span>
            </li>
            <li>
              <strong>De regie van ISS</strong>
              <span>Hoe de sitemanager teams, leveranciers, data en klantafspraken verbindt tot één bestuurbare operatie.</span>
            </li>
          </ul>
        </div>
      </div>
    </header>
  </div>

  <main class="main">
    <section class="control-panel">
      <div class="control-top">
        <div class="control-title">
          <h3>Selecteer een journey</h3>
          <p>
            Elke journey toont de belangrijkste contactmomenten, de ISS-diensten die op dat moment relevant zijn,
            de technologie die deze dienstverlening ondersteunt en de waarde die hiermee voor de klantlocatie wordt gerealiseerd.
          </p>
        </div>
      </div>

      <div class="tabs">
        <button class="tab active" data-tab="resident" onclick="switchView('resident', this)">
          <small>Journey 01</small>
          <strong>Pandbewoner</strong>
          <span>De medewerker die dagelijks op locatie werkt en de dienstverlening vooral ervaart via comfort, beschikbaarheid en gemak.</span>
        </button>
        <button class="tab" data-tab="visitor" onclick="switchView('visitor', this)">
          <small>Journey 02</small>
          <strong>Bezoeker</strong>
          <span>De externe gast die de kwaliteit van de klantorganisatie mede ervaart via ontvangst, gastvrijheid en omgevingskwaliteit.</span>
        </button>
        <button class="tab" data-tab="manager" onclick="switchView('manager', this)">
          <small>Journey 03</small>
          <strong>Sitemanager</strong>
          <span>De regisseur die teams, servicelevels, incidenten, klantcontact en rapportage in samenhang aanstuurt.</span>
        </button>
      </div>
    </section>

    <section class="view active" id="resident">
      <div class="panel">
        <div class="panel-header">
          <div class="panel-kicker">Pandbewoner journey</div>
          <h2>De dagelijkse werkervaring op locatie</h2>
          <p>
            Voor de pandbewoner is goede facilitaire dienstverlening grotendeels onzichtbaar. Juist daarin zit de waarde: het gebouw is klaar,
            de omgeving ondersteunt productiviteit en eventuele verstoringen worden snel en professioneel opgelost.
          </p>
        </div>
        <div class="journey">
          <div class="step">
            <div class="step-rail">
              <div class="step-index">01</div>
              <div class="step-phase">Voor start</div>
              <div class="step-line"></div>
            </div>
            <div class="step-card open" onclick="toggleStep(this)">
              <div class="step-top">
                <div>
                  <div class="step-label">Locatie gereed voor gebruik</div>
                  <div class="step-title">Voorbereiding van het gebouw vóór aankomst van medewerkers</div>
                  <div class="step-summary">De werkdag begint voordat de eerste medewerker arriveert. ISS zorgt dat het gebouw schoon, veilig, toegankelijk en operationeel gereed is.</div>
                </div>
                <div class="step-toggle">+</div>
              </div>
              <div class="step-detail">
                <div class="detail-grid">
                  <div class="detail-box">
                    <h4>ISS dienstverlening</h4>
                    <ul>
                      <li>Schoonmaak en reset van werkplekken, publieke ruimten en sanitair</li>
                      <li>Openingsrondes, veiligheidschecks en toegangsvoorbereiding</li>
                      <li>Controle van klimaat, verlichting en gebouwstatus</li>
                    </ul>
                  </div>
                  <div class="detail-box">
                    <h4>Technologie en ondersteuning</h4>
                    <ul>
                      <li>IoT-sensoren voor bezetting, temperatuur en luchtkwaliteit</li>
                      <li>Gebouwbeheersystemen voor klimaat- en lichtinstellingen</li>
                      <li>Dashboards en automatische signalering van afwijkingen</li>
                    </ul>
                  </div>
                </div>
                <div class="badge-row">
                  <span class="badge service">Dienst: Cleaning, Security, Workplace readiness</span>
                  <span class="badge tech">Technologie: IoT, BMS, rapportage</span>
                  <span class="badge value">Waarde: direct productieve start van de dag</span>
                </div>
              </div>
            </div>
          </div>

          <div class="step">
            <div class="step-rail">
              <div class="step-index">02</div>
              <div class="step-phase">Aankomst</div>
              <div class="step-line"></div>
            </div>
            <div class="step-card" onclick="toggleStep(this)">
              <div class="step-top">
                <div>
                  <div class="step-label">Toegang en eerste beleving</div>
                  <div class="step-title">Binnenkomst in een veilige, verzorgde en gastvrije omgeving</div>
                  <div class="step-summary">De kwaliteit van de locatie wordt direct ervaren bij entree, routing, receptie en algemene uitstraling van het pand.</div>
                </div>
                <div class="step-toggle">+</div>
              </div>
              <div class="step-detail">
                <div class="detail-grid">
                  <div class="detail-box">
                    <h4>ISS dienstverlening</h4>
                    <ul>
                      <li>Receptiedienstverlening en front-of-house support</li>
                      <li>Beheer van toegang, routing en publieke ruimten</li>
                      <li>Onderhoud van representatieve entrees en ontvangstgebieden</li>
                    </ul>
                  </div>
                  <div class="detail-box">
                    <h4>Technologie en ondersteuning</h4>
                    <ul>
                      <li>Digitale toegangscontrole en badgeprocessen</li>
                      <li>Bezoekers- en ontvangstsystemen</li>
                      <li>Datasturing op bezetting en piekmomenten in ontvangstzones</li>
                    </ul>
                  </div>
                </div>
                <div class="badge-row">
                  <span class="badge service">Dienst: Hospitality, Access, Reception</span>
                  <span class="badge tech">Technologie: Check-in flows, occupancy insights</span>
                  <span class="badge value">Waarde: veilige en professionele ontvangst</span>
                </div>
              </div>
            </div>
          </div>

          <div class="step">
            <div class="step-rail">
              <div class="step-index">03</div>
              <div class="step-phase">Werkdag</div>
              <div class="step-line"></div>
            </div>
            <div class="step-card" onclick="toggleStep(this)">
              <div class="step-top">
                <div>
                  <div class="step-label">Ondersteuning tijdens gebruik</div>
                  <div class="step-title">Een werkplek die continu beschikbaar, schoon en comfortabel blijft</div>
                  <div class="step-summary">Tijdens de werkdag draait ISS op de achtergrond mee: van klimaat en schoonmaak tot catering, post, voorraad en werkplekomgeving.</div>
                </div>
                <div class="step-toggle">+</div>
              </div>
              <div class="step-detail">
                <div class="detail-grid">
                  <div class="detail-box">
                    <h4>ISS dienstverlening</h4>
                    <ul>
                      <li>Werkplekonderhoud, day cleaning en sanitaire services</li>
                      <li>Catering, pantry support en hospitality services</li>
                      <li>Post-, voorraad- en supportprocessen op locatie</li>
                    </ul>
                  </div>
                  <div class="detail-box">
                    <h4>Technologie en ondersteuning</h4>
                    <ul>
                      <li>Sensoriek voor gebruiksintensiteit van ruimten en assets</li>
                      <li>Datagedreven schoonmaak en replenishment op basis van behoefte</li>
